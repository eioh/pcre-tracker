{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    // wrangler types が生成する worker-configuration.d.ts（Cloudflare ランタイム型 + Env）を型解決に含める。
    "types": ["./worker-configuration.d.ts"],
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.worker.tsbuildinfo"
  },
  // worker 本体に加え、Worker から import する DOM 非依存のドメインモジュール（同期スキーマ関連）を含める。
  "include": [
    "worker",
    "worker-configuration.d.ts",
    "src/domain/sync.ts",
    "src/domain/storageKeys.ts",
    "src/domain/connectRankCalcSchema.ts",
    "src/domain/schemas.ts",
    "src/domain/levels.ts",
    "src/domain/types.ts"
  ]
}
